//@version=5
indicator("OB & Rejection Blocks [Smart Money]", overlay=true, max_boxes_count=200, max_lines_count=200, max_labels_count=200)

// ─────────────────────────────────────────────
//  SETTINGS
// ─────────────────────────────────────────────
grp1 = "Order Block Settings"
showOB       = input.bool(true,  "Show Order Blocks",            group=grp1)
obBullColor  = input.color(color.new(#00e676, 75), "Bullish OB Color",  group=grp1)
obBearColor  = input.color(color.new(#ff1744, 75), "Bearish OB Color",  group=grp1)
obBorderBull = input.color(color.new(#00e676, 0),  "Bullish OB Border", group=grp1)
obBorderBear = input.color(color.new(#ff1744, 0),  "Bearish OB Border", group=grp1)
obLookback   = input.int(50, "OB Lookback Bars", minval=10, maxval=200, group=grp1)

grp2 = "Rejection Block Settings"
showRB       = input.bool(true,  "Show Rejection Blocks",        group=grp2)
rbBorderBull = input.color(color.new(#29b6f6, 0),  "Bullish RB Color",  group=grp2)
rbBorderBear = input.color(color.new(#ff9800, 0),  "Bearish RB Color",  group=grp2)

grp3 = "Structure Settings"
swingLen     = input.int(5, "Swing High/Low Length", minval=2, maxval=20, group=grp3)
showLabels   = input.bool(true, "Show Labels", group=grp3)
labelSize    = input.string("small", "Label Size", options=["tiny","small","normal"], group=grp3)

// ─────────────────────────────────────────────
//  HELPERS
// ─────────────────────────────────────────────
lsize = labelSize == "tiny" ? size.tiny : labelSize == "small" ? size.small : size.normal

// ─────────────────────────────────────────────
//  ORDER BLOCK ARRAYS
//  Each OB stores: box, label, top, bot
// ─────────────────────────────────────────────
var ob_bear_top = array.new_float(0)
var ob_bear_bot = array.new_float(0)
var ob_bear_box = array.new_box(0)
var ob_bear_lbl = array.new_label(0)

var ob_bull_top = array.new_float(0)
var ob_bull_bot = array.new_float(0)
var ob_bull_box = array.new_box(0)
var ob_bull_lbl = array.new_label(0)

// ─────────────────────────────────────────────
//  OB DETECTION
// ─────────────────────────────────────────────
isBearishImpulse    = close[1] < open[1] and close[2] < open[2] and close[1] < low[3]
isBullishPrevCandle = close[3] > open[3]
isBullishImpulse    = close[1] > open[1] and close[2] > open[2] and close[1] > high[3]
isBearishPrevCandle = close[3] < open[3]

if showOB
    // ── Bearish OB ──
    if isBearishImpulse and isBullishPrevCandle
        ob_level  = close[3]
        box_top   = math.max(open[3], close[3])
        box_bot   = ob_level - syminfo.mintick * 2
        right_bar = bar_index + obLookback
        b = box.new(bar_index - 3, box_top, right_bar, box_bot,
             border_color=obBorderBear, bgcolor=obBearColor, border_width=1)
        lbl = label.new(right_bar, box_top, "OB ▼",
             xloc=xloc.bar_index, yloc=yloc.price,
             style=label.style_label_left,
             color=color.new(#ff1744, 0), textcolor=color.white, size=lsize)
        array.push(ob_bear_top, box_top)
        array.push(ob_bear_bot, box_bot)
        array.push(ob_bear_box, b)
        array.push(ob_bear_lbl, lbl)

    // ── Bullish OB ──
    if isBullishImpulse and isBearishPrevCandle
        ob_level  = close[3]
        box_top   = ob_level + syminfo.mintick * 2
        box_bot   = math.min(open[3], close[3])
        right_bar = bar_index + obLookback
        b = box.new(bar_index - 3, box_top, right_bar, box_bot,
             border_color=obBorderBull, bgcolor=obBullColor, border_width=1)
        lbl = label.new(right_bar, box_bot, "OB ▲",
             xloc=xloc.bar_index, yloc=yloc.price,
             style=label.style_label_left,
             color=color.new(#00e676, 0), textcolor=color.white, size=lsize)
        array.push(ob_bull_top, box_top)
        array.push(ob_bull_bot, box_bot)
        array.push(ob_bull_box, b)
        array.push(ob_bull_lbl, lbl)

// ─────────────────────────────────────────────
//  OB MITIGATION + LABEL UPDATE
//  Delete box & label when tapped
//  Otherwise keep label pinned to right edge
// ─────────────────────────────────────────────
if showOB
    // Bearish OBs — mitigated when price taps into zone
    i = 0
    while i < array.size(ob_bear_box)
        top = array.get(ob_bear_top, i)
        bot = array.get(ob_bear_bot, i)
        b   = array.get(ob_bear_box, i)
        lbl = array.get(ob_bear_lbl, i)
        if high >= bot
            box.delete(b)
            label.delete(lbl)
            array.remove(ob_bear_top, i)
            array.remove(ob_bear_bot, i)
            array.remove(ob_bear_box, i)
            array.remove(ob_bear_lbl, i)
        else
            new_right = bar_index + 5
            box.set_right(b, new_right)
            label.set_x(lbl, new_right)
            label.set_y(lbl, top)
            i += 1

    // Bullish OBs — mitigated when price taps into zone
    j = 0
    while j < array.size(ob_bull_box)
        top = array.get(ob_bull_top, j)
        bot = array.get(ob_bull_bot, j)
        b   = array.get(ob_bull_box, j)
        lbl = array.get(ob_bull_lbl, j)
        if low <= top
            box.delete(b)
            label.delete(lbl)
            array.remove(ob_bull_top, j)
            array.remove(ob_bull_bot, j)
            array.remove(ob_bull_box, j)
            array.remove(ob_bull_lbl, j)
        else
            new_right = bar_index + 5
            box.set_right(b, new_right)
            label.set_x(lbl, new_right)
            label.set_y(lbl, bot)
            j += 1

// ─────────────────────────────────────────────
//  REJECTION BLOCK ARRAYS
// ─────────────────────────────────────────────
var rb_bear_level = array.new_float(0)
var rb_bear_line  = array.new_line(0)
var rb_bear_lbl   = array.new_label(0)

var rb_bull_level = array.new_float(0)
var rb_bull_line  = array.new_line(0)
var rb_bull_lbl   = array.new_label(0)

// ─────────────────────────────────────────────
//  RB DETECTION (A/V formations on close prices)
// ─────────────────────────────────────────────
isAFormation = true
for k = 1 to swingLen
    if close[swingLen] <= close[swingLen - k] or close[swingLen] <= close[swingLen + k]
        isAFormation := false

isVFormation = true
for k = 1 to swingLen
    if close[swingLen] >= close[swingLen - k] or close[swingLen] >= close[swingLen + k]
        isVFormation := false

if showRB
    // ── Bearish RB (A-form = resistance) ──
    if isAFormation
        lvl       = close[swingLen]
        right_bar = bar_index + obLookback
        ln = line.new(bar_index - swingLen, lvl, right_bar, lvl,
             color=rbBorderBear, width=1, style=line.style_dashed)
        lbl = label.new(right_bar, lvl, "RB ▼",
             xloc=xloc.bar_index, yloc=yloc.price,
             style=label.style_label_left,
             color=color.new(#ff9800, 0), textcolor=color.white, size=lsize)
        array.push(rb_bear_level, lvl)
        array.push(rb_bear_line,  ln)
        array.push(rb_bear_lbl,   lbl)

    // ── Bullish RB (V-form = support) ──
    if isVFormation
        lvl       = close[swingLen]
        right_bar = bar_index + obLookback
        ln = line.new(bar_index - swingLen, lvl, right_bar, lvl,
             color=rbBorderBull, width=1, style=line.style_dashed)
        lbl = label.new(right_bar, lvl, "RB ▲",
             xloc=xloc.bar_index, yloc=yloc.price,
             style=label.style_label_left,
             color=color.new(#29b6f6, 0), textcolor=color.white, size=lsize)
        array.push(rb_bull_level, lvl)
        array.push(rb_bull_line,  ln)
        array.push(rb_bull_lbl,   lbl)

// ─────────────────────────────────────────────
//  RB MITIGATION + LABEL UPDATE
// ─────────────────────────────────────────────
if showRB
    // Bearish RBs — mitigated when close breaks above level
    ii = 0
    while ii < array.size(rb_bear_line)
        lvl = array.get(rb_bear_level, ii)
        ln  = array.get(rb_bear_line,  ii)
        lbl = array.get(rb_bear_lbl,   ii)
        if close > lvl
            line.delete(ln)
            label.delete(lbl)
            array.remove(rb_bear_level, ii)
            array.remove(rb_bear_line,  ii)
            array.remove(rb_bear_lbl,   ii)
        else
            new_right = bar_index + 5
            line.set_x2(ln, new_right)
            label.set_x(lbl, new_right)
            ii += 1

    // Bullish RBs — mitigated when close breaks below level
    jj = 0
    while jj < array.size(rb_bull_line)
        lvl = array.get(rb_bull_level, jj)
        ln  = array.get(rb_bull_line,  jj)
        lbl = array.get(rb_bull_lbl,   jj)
        if close < lvl
            line.delete(ln)
            label.delete(lbl)
            array.remove(rb_bull_level, jj)
            array.remove(rb_bull_line,  jj)
            array.remove(rb_bull_lbl,   jj)
        else
            new_right = bar_index + 5
            line.set_x2(ln, new_right)
            label.set_x(lbl, new_right)
            jj += 1

// ─────────────────────────────────────────────
//  STRONG HIGH / LOW MARKERS
// ─────────────────────────────────────────────
grp4 = "Strong High/Low"
showSHL = input.bool(true, "Show Strong High/Low", group=grp4)

swingH = ta.pivothigh(high, swingLen, swingLen)
swingL = ta.pivotlow(low,  swingLen, swingLen)

var float lastSwingHigh = na
var float lastSwingLow  = na

if not na(swingH)
    lastSwingHigh := swingH
if not na(swingL)
    lastSwingLow  := swingL

bodyBreakBull = not na(lastSwingHigh) and close > lastSwingHigh and close[1] > open[1]
bodyBreakBear = not na(lastSwingLow)  and close < lastSwingLow  and close[1] < open[1]

if showSHL
    if bodyBreakBull
        label.new(bar_index, low, "SL ↑", style=label.style_label_up,
             color=color.new(#00e676, 0), textcolor=color.white, size=lsize)
    if bodyBreakBear
        label.new(bar_index, high, "SH ↓", style=label.style_label_down,
             color=color.new(#ff1744, 0), textcolor=color.white, size=lsize)
