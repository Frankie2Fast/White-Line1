//@version=6
indicator("MTF Closest Swing Levels (1H / 15m / 5m)", overlay=true, max_lines_count=50, max_labels_count=50)

// ─────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────
lookback_1h  = input.int(10, "1H Lookback",  minval=3, maxval=50, group="Lookback")
lookback_15m = input.int(10, "15m Lookback", minval=3, maxval=50, group="Lookback")
lookback_5m  = input.int(10, "5m Lookback",  minval=3, maxval=50, group="Lookback")

show_1h  = input.bool(true, "Show 1H",  group="Visibility")
show_15m = input.bool(true, "Show 15m", group="Visibility")
show_5m  = input.bool(true, "Show 5m",  group="Visibility")

col_1h  = input.color(color.new(#FF9800, 0), "1H Color",  group="Colors")
col_15m = input.color(color.new(#2196F3, 0), "15m Color", group="Colors")
col_5m  = input.color(color.new(#4CAF50, 0), "5m Color",  group="Colors")

// ─────────────────────────────────────────────
// CLOSEST LEVEL LOGIC (runs inside request.security)
// Scans last 50 bars on the HTF for the nearest unswept pivot
// ─────────────────────────────────────────────
f_closest_sh(lb) =>
    result = float(na)
    for i = lb to 200
        ph = ta.pivothigh(high, lb, lb)[i - lb]
        if not na(ph) and ph > close
            if na(result) or ph < result
                result := ph
    result

f_closest_sl(lb) =>
    result = float(na)
    for i = lb to 200
        pl = ta.pivotlow(low, lb, lb)[i - lb]
        if not na(pl) and pl < close
            if na(result) or pl > result
                result := pl
    result

// ─────────────────────────────────────────────
// PULL FROM EACH TIMEFRAME
// ─────────────────────────────────────────────
[h1_sh, h1_sl] = request.security("", "60",
     [f_closest_sh(lookback_1h), f_closest_sl(lookback_1h)],
     lookahead=barmerge.lookahead_off)

[m15_sh, m15_sl] = request.security("", "15",
     [f_closest_sh(lookback_15m), f_closest_sl(lookback_15m)],
     lookahead=barmerge.lookahead_off)

[m5_sh, m5_sl] = request.security("", "5",
     [f_closest_sh(lookback_5m), f_closest_sl(lookback_5m)],
     lookahead=barmerge.lookahead_off)

// ─────────────────────────────────────────────
// PERSISTENT LINE + LABEL VARS
// ─────────────────────────────────────────────
var line  l_h1_sh  = na, l_h1_sl  = na
var line  l_m15_sh = na, l_m15_sl = na
var line  l_m5_sh  = na, l_m5_sl  = na
var label lb_h1_sh = na, lb_h1_sl  = na
var label lb_m15_sh= na, lb_m15_sl = na
var label lb_m5_sh = na, lb_m5_sl  = na

// ─────────────────────────────────────────────
// DRAW HELPER — deletes old, draws fresh
// ─────────────────────────────────────────────
f_update_line(ln, price, col) =>
    line.delete(ln)
    if not na(price)
        line.new(bar_index, price, bar_index + 1, price,
             color  = col,
             width  = 2,
             style  = line.style_dotted,
             extend = extend.right)
    else
        line(na)

f_update_label(lbl, price, col, txt) =>
    label.delete(lbl)
    if not na(price)
        label.new(bar_index + 1, price, txt,
             color     = color.new(col, 85),
             textcolor = col,
             style     = label.style_label_right,
             size      = size.small)
    else
        label(na)

// ─────────────────────────────────────────────
// UPDATE ON EVERY BAR
// ─────────────────────────────────────────────

// 1H
if show_1h
    l_h1_sh   := f_update_line(l_h1_sh,  h1_sh, col_1h)
    l_h1_sl   := f_update_line(l_h1_sl,  h1_sl, col_1h)
    lb_h1_sh  := f_update_label(lb_h1_sh, h1_sh, col_1h, "1H SH")
    lb_h1_sl  := f_update_label(lb_h1_sl, h1_sl, col_1h, "1H SL")

// 15m
if show_15m
    l_m15_sh  := f_update_line(l_m15_sh,  m15_sh, col_15m)
    l_m15_sl  := f_update_line(l_m15_sl,  m15_sl, col_15m)
    lb_m15_sh := f_update_label(lb_m15_sh, m15_sh, col_15m, "15m SH")
    lb_m15_sl := f_update_label(lb_m15_sl, m15_sl, col_15m, "15m SL")

// 5m
if show_5m
    l_m5_sh   := f_update_line(l_m5_sh,  m5_sh, col_5m)
    l_m5_sl   := f_update_line(l_m5_sl,  m5_sl, col_5m)
    lb_m5_sh  := f_update_label(lb_m5_sh, m5_sh, col_5m, "5m SH")
    lb_m5_sl  := f_update_label(lb_m5_sl, m5_sl, col_5m, "5m SL")
