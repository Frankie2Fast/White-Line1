//@version=6
indicator("MTF Closest Swing Levels (1H / 15m / 5m)", overlay=true, max_lines_count=200, max_labels_count=200)

// ─────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────
lookback_1h  = input.int(10, "1H Lookback",  minval=3, maxval=50, group="Lookback Settings")
lookback_15m = input.int(10, "15m Lookback", minval=3, maxval=50, group="Lookback Settings")
lookback_5m  = input.int(10, "5m Lookback",  minval=3, maxval=50, group="Lookback Settings")

show_1h  = input.bool(true, "Show 1H",  group="Visibility")
show_15m = input.bool(true, "Show 15m", group="Visibility")
show_5m  = input.bool(true, "Show 5m",  group="Visibility")

col_1h  = input.color(color.new(#FF9800, 0), "1H Color",  group="Colors")
col_15m = input.color(color.new(#2196F3, 0), "15m Color", group="Colors")
col_5m  = input.color(color.new(#4CAF50, 0), "5m Color",  group="Colors")

lbl_size = input.string("Small", "Label Size", options=["Tiny","Small","Normal"], group="Style")

// ─────────────────────────────────────────────
// HELPERS
// ─────────────────────────────────────────────
f_label_size(s) =>
    switch s
        "Tiny"   => size.tiny
        "Small"  => size.small
        "Normal" => size.normal
        =>          size.small

// ─────────────────────────────────────────────
// REQUEST SECURITY — SWING ARRAYS PER TF
// We pull the last N pivot highs/lows from each TF,
// sorted so index 0 = closest to current price.
// ─────────────────────────────────────────────

// How many swing levels to cache per TF (we show only the closest unswept one)
MAX_SWINGS = 10

// ── 1H ──────────────────────────────────────
[h1_ph0, h1_ph1, h1_ph2, h1_ph3, h1_ph4,
 h1_ph5, h1_ph6, h1_ph7, h1_ph8, h1_ph9] = request.security("", "60",
    [ta.pivothigh(high, lookback_1h, lookback_1h)[0],
     ta.pivothigh(high, lookback_1h, lookback_1h)[1],
     ta.pivothigh(high, lookback_1h, lookback_1h)[2],
     ta.pivothigh(high, lookback_1h, lookback_1h)[3],
     ta.pivothigh(high, lookback_1h, lookback_1h)[4],
     ta.pivothigh(high, lookback_1h, lookback_1h)[5],
     ta.pivothigh(high, lookback_1h, lookback_1h)[6],
     ta.pivothigh(high, lookback_1h, lookback_1h)[7],
     ta.pivothigh(high, lookback_1h, lookback_1h)[8],
     ta.pivothigh(high, lookback_1h, lookback_1h)[9]],
    lookahead=barmerge.lookahead_off)

[h1_pl0, h1_pl1, h1_pl2, h1_pl3, h1_pl4,
 h1_pl5, h1_pl6, h1_pl7, h1_pl8, h1_pl9] = request.security("", "60",
    [ta.pivotlow(low, lookback_1h, lookback_1h)[0],
     ta.pivotlow(low, lookback_1h, lookback_1h)[1],
     ta.pivotlow(low, lookback_1h, lookback_1h)[2],
     ta.pivotlow(low, lookback_1h, lookback_1h)[3],
     ta.pivotlow(low, lookback_1h, lookback_1h)[4],
     ta.pivotlow(low, lookback_1h, lookback_1h)[5],
     ta.pivotlow(low, lookback_1h, lookback_1h)[6],
     ta.pivotlow(low, lookback_1h, lookback_1h)[7],
     ta.pivotlow(low, lookback_1h, lookback_1h)[8],
     ta.pivotlow(low, lookback_1h, lookback_1h)[9]],
    lookahead=barmerge.lookahead_off)

// ── 15m ─────────────────────────────────────
[m15_ph0, m15_ph1, m15_ph2, m15_ph3, m15_ph4,
 m15_ph5, m15_ph6, m15_ph7, m15_ph8, m15_ph9] = request.security("", "15",
    [ta.pivothigh(high, lookback_15m, lookback_15m)[0],
     ta.pivothigh(high, lookback_15m, lookback_15m)[1],
     ta.pivothigh(high, lookback_15m, lookback_15m)[2],
     ta.pivothigh(high, lookback_15m, lookback_15m)[3],
     ta.pivothigh(high, lookback_15m, lookback_15m)[4],
     ta.pivothigh(high, lookback_15m, lookback_15m)[5],
     ta.pivothigh(high, lookback_15m, lookback_15m)[6],
     ta.pivothigh(high, lookback_15m, lookback_15m)[7],
     ta.pivothigh(high, lookback_15m, lookback_15m)[8],
     ta.pivothigh(high, lookback_15m, lookback_15m)[9]],
    lookahead=barmerge.lookahead_off)

[m15_pl0, m15_pl1, m15_pl2, m15_pl3, m15_pl4,
 m15_pl5, m15_pl6, m15_pl7, m15_pl8, m15_pl9] = request.security("", "15",
    [ta.pivotlow(low, lookback_15m, lookback_15m)[0],
     ta.pivotlow(low, lookback_15m, lookback_15m)[1],
     ta.pivotlow(low, lookback_15m, lookback_15m)[2],
     ta.pivotlow(low, lookback_15m, lookback_15m)[3],
     ta.pivotlow(low, lookback_15m, lookback_15m)[4],
     ta.pivotlow(low, lookback_15m, lookback_15m)[5],
     ta.pivotlow(low, lookback_15m, lookback_15m)[6],
     ta.pivotlow(low, lookback_15m, lookback_15m)[7],
     ta.pivotlow(low, lookback_15m, lookback_15m)[8],
     ta.pivotlow(low, lookback_15m, lookback_15m)[9]],
    lookahead=barmerge.lookahead_off)

// ── 5m ──────────────────────────────────────
[m5_ph0, m5_ph1, m5_ph2, m5_ph3, m5_ph4,
 m5_ph5, m5_ph6, m5_ph7, m5_ph8, m5_ph9] = request.security("", "5",
    [ta.pivothigh(high, lookback_5m, lookback_5m)[0],
     ta.pivothigh(high, lookback_5m, lookback_5m)[1],
     ta.pivothigh(high, lookback_5m, lookback_5m)[2],
     ta.pivothigh(high, lookback_5m, lookback_5m)[3],
     ta.pivothigh(high, lookback_5m, lookback_5m)[4],
     ta.pivothigh(high, lookback_5m, lookback_5m)[5],
     ta.pivothigh(high, lookback_5m, lookback_5m)[6],
     ta.pivothigh(high, lookback_5m, lookback_5m)[7],
     ta.pivothigh(high, lookback_5m, lookback_5m)[8],
     ta.pivothigh(high, lookback_5m, lookback_5m)[9]],
    lookahead=barmerge.lookahead_off)

[m5_pl0, m5_pl1, m5_pl2, m5_pl3, m5_pl4,
 m5_pl5, m5_pl6, m5_pl7, m5_pl8, m5_pl9] = request.security("", "5",
    [ta.pivotlow(low, lookback_5m, lookback_5m)[0],
     ta.pivotlow(low, lookback_5m, lookback_5m)[1],
     ta.pivotlow(low, lookback_5m, lookback_5m)[2],
     ta.pivotlow(low, lookback_5m, lookback_5m)[3],
     ta.pivotlow(low, lookback_5m, lookback_5m)[4],
     ta.pivotlow(low, lookback_5m, lookback_5m)[5],
     ta.pivotlow(low, lookback_5m, lookback_5m)[6],
     ta.pivotlow(low, lookback_5m, lookback_5m)[7],
     ta.pivotlow(low, lookback_5m, lookback_5m)[8],
     ta.pivotlow(low, lookback_5m, lookback_5m)[9]],
    lookahead=barmerge.lookahead_off)

// ─────────────────────────────────────────────
// BUILD ARRAYS FROM TUPLE VALUES
// ─────────────────────────────────────────────
f_build_highs(v0, v1, v2, v3, v4, v5, v6, v7, v8, v9) =>
    arr = array.new<float>()
    if not na(v0) array.push(arr, v0)
    if not na(v1) array.push(arr, v1)
    if not na(v2) array.push(arr, v2)
    if not na(v3) array.push(arr, v3)
    if not na(v4) array.push(arr, v4)
    if not na(v5) array.push(arr, v5)
    if not na(v6) array.push(arr, v6)
    if not na(v7) array.push(arr, v7)
    if not na(v8) array.push(arr, v8)
    if not na(v9) array.push(arr, v9)
    arr

f_build_lows(v0, v1, v2, v3, v4, v5, v6, v7, v8, v9) =>
    arr = array.new<float>()
    if not na(v0) array.push(arr, v0)
    if not na(v1) array.push(arr, v1)
    if not na(v2) array.push(arr, v2)
    if not na(v3) array.push(arr, v3)
    if not na(v4) array.push(arr, v4)
    if not na(v5) array.push(arr, v5)
    if not na(v6) array.push(arr, v6)
    if not na(v7) array.push(arr, v7)
    if not na(v8) array.push(arr, v8)
    if not na(v9) array.push(arr, v9)
    arr

// ─────────────────────────────────────────────
// FIND CLOSEST UNSWEPT LEVEL
// For highs: closest = lowest value ABOVE current close (nearest resistance)
// For lows:  closest = highest value BELOW current close (nearest support)
// If swept (close above high / close below low), skip to next
// ─────────────────────────────────────────────
f_closest_high(arr) =>
    result = float(na)
    if array.size(arr) > 0
        // Filter to only levels above current close, find the minimum (closest above)
        best = float(na)
        for k = 0 to array.size(arr) - 1
            val = array.get(arr, k)
            if not na(val) and val > close
                if na(best) or val < best
                    best := val
        result := best
    result

f_closest_low(arr) =>
    result = float(na)
    if array.size(arr) > 0
        // Filter to only levels below current close, find the maximum (closest below)
        best = float(na)
        for k = 0 to array.size(arr) - 1
            val = array.get(arr, k)
            if not na(val) and val < close
                if na(best) or val > best
                    best := val
        result := best
    result

// ─────────────────────────────────────────────
// COMPUTE CLOSEST LEVELS
// ─────────────────────────────────────────────
h1_highs  = f_build_highs(h1_ph0,  h1_ph1,  h1_ph2,  h1_ph3,  h1_ph4,  h1_ph5,  h1_ph6,  h1_ph7,  h1_ph8,  h1_ph9)
h1_lows   = f_build_lows (h1_pl0,  h1_pl1,  h1_pl2,  h1_pl3,  h1_pl4,  h1_pl5,  h1_pl6,  h1_pl7,  h1_pl8,  h1_pl9)
m15_highs = f_build_highs(m15_ph0, m15_ph1, m15_ph2, m15_ph3, m15_ph4, m15_ph5, m15_ph6, m15_ph7, m15_ph8, m15_ph9)
m15_lows  = f_build_lows (m15_pl0, m15_pl1, m15_pl2, m15_pl3, m15_pl4, m15_pl5, m15_pl6, m15_pl7, m15_pl8, m15_pl9)
m5_highs  = f_build_highs(m5_ph0,  m5_ph1,  m5_ph2,  m5_ph3,  m5_ph4,  m5_ph5,  m5_ph6,  m5_ph7,  m5_ph8,  m5_ph9)
m5_lows   = f_build_lows (m5_pl0,  m5_pl1,  m5_pl2,  m5_pl3,  m5_pl4,  m5_pl5,  m5_pl6,  m5_pl7,  m5_pl8,  m5_pl9)

h1_sh  = f_closest_high(h1_highs)
h1_sl  = f_closest_low(h1_lows)
m15_sh = f_closest_high(m15_highs)
m15_sl = f_closest_low(m15_lows)
m5_sh  = f_closest_high(m5_highs)
m5_sl  = f_closest_low(m5_lows)

// ─────────────────────────────────────────────
// DRAW LINES + LABELS
// Delete previous bar's objects, redraw fresh each bar
// ─────────────────────────────────────────────
var line   l_h1_sh  = na,  l_h1_sl  = na
var line   l_m15_sh = na,  l_m15_sl = na
var line   l_m5_sh  = na,  l_m5_sl  = na
var label  lb_h1_sh = na,  lb_h1_sl = na
var label  lb_m15_sh = na, lb_m15_sl = na
var label  lb_m5_sh = na,  lb_m5_sl = na

f_draw(ln, lbl, price, col, lbl_txt) =>
    line.delete(ln)
    label.delete(lbl)
    new_ln  = line(na)
    new_lbl = label(na)
    if not na(price)
        new_ln := line.new(
             x1     = bar_index - 1,
             y1     = price,
             x2     = bar_index,
             y2     = price,
             color  = col,
             width  = 2,
             style  = line.style_dotted,
             extend = extend.right)
        new_lbl := label.new(
             x         = bar_index,
             y         = price,
             text      = lbl_txt,
             color     = color.new(col, 85),
             textcolor = col,
             style     = label.style_label_left,
             size      = f_label_size(lbl_size))
    [new_ln, new_lbl]

sz = f_label_size(lbl_size)

if barstate.islast
    // 1H
    if show_1h
        [ln1, lb1] = f_draw(l_h1_sh,  lb_h1_sh,  h1_sh,  col_1h,  "1H High")
        l_h1_sh  := ln1
        lb_h1_sh := lb1
        [ln2, lb2] = f_draw(l_h1_sl,  lb_h1_sl,  h1_sl,  col_1h,  "1H Low")
        l_h1_sl  := ln2
        lb_h1_sl := lb2

    // 15m
    if show_15m
        [ln3, lb3] = f_draw(l_m15_sh, lb_m15_sh, m15_sh, col_15m, "15m High")
        l_m15_sh  := ln3
        lb_m15_sh := lb3
        [ln4, lb4] = f_draw(l_m15_sl, lb_m15_sl, m15_sl, col_15m, "15m Low")
        l_m15_sl  := ln4
        lb_m15_sl := lb4

    // 5m
    if show_5m
        [ln5, lb5] = f_draw(l_m5_sh,  lb_m5_sh,  m5_sh,  col_5m,  "5m High")
        l_m5_sh  := ln5
        lb_m5_sh := lb5
        [ln6, lb6] = f_draw(l_m5_sl,  lb_m5_sl,  m5_sl,  col_5m,  "5m Low")
        l_m5_sl  := ln6
        lb_m5_sl := lb6
